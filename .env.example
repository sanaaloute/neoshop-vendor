# V1 Vendor Panel API (must be the public gateway origin)
NEXT_PUBLIC_API_BASE_URL=

# Client-side auth config
NEXT_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh

# Supabase config for storage client and realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Socket.IO realtime server (defaults to NEXT_PUBLIC_API_BASE_URL if unset)
NEXT_PUBLIC_SOCKET_IO_URL=
NEXT_PUBLIC_SOCKET_IO_PATH=/socket.io

# Optional build identifier surfaced by the /_health endpoint
NEXT_PUBLIC_BUILD_ID=
