# V1 Vendor Panel API
NEXT_PUBLIC_API_BASE_URL=

# Client-side auth config
NEXT_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh

# Cookie security: set to "true" only for HTTPS (including *.vercel.app).
# On plain HTTP localhost it MUST be absent/false or cookies are dropped silently.
COOKIE_SECURE=

# Supabase config for storage client and realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional build identifier surfaced by the /_health endpoint
NEXT_PUBLIC_BUILD_ID=

# Local dev
# COOKIE_SECURE=

# JWT verification strategy (secure by default)
# Tokens are Supabase JWTs (typically ES256). Signature verification is ON by
# default. Set AUTH_ISSUER to the Supabase auth URL so the JWKS endpoint can be
# derived automatically, or set JWKS_URL / SUPABASE_JWT_SECRET explicitly.
# In local dev, if the Supabase JWKS is unreachable, set JWT_VERIFY_SIGNATURE=false.
AUTH_ISSUER=
JWT_ALGORITHMS=ES256,HS256
SUPABASE_JWT_SECRET=
JWKS_URL=
JWT_VERIFY_SIGNATURE=
