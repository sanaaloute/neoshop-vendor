# NeoShop Vendor Dashboard — environment variables

# --- Required: public gateway origin ---
# The gateway root WITHOUT /api/v1; the codebase appends /api/v1 to endpoint paths.
NEXT_PUBLIC_API_BASE_URL=https://api.barkosem.com

# --- Required if doing server-side auth refresh / me lookup ---
NEXT_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh
NEXT_PUBLIC_AUTH_ME_PATH=/auth/me

# --- Optional: realtime ---
# Socket.IO server origin. Defaults to NEXT_PUBLIC_API_BASE_URL when unset.
NEXT_PUBLIC_SOCKET_IO_URL=

# --- Server-side JWT verification (middleware / API routes) ---
AUTH_ISSUER=https://<project>.supabase.co/auth/v1
JWT_VERIFY_SIGNATURE=true
JWT_ALGORITHMS=ES256
AUTH_AUDIENCE=authenticated

# --- Optional: build / dev tooling ---
NEXT_PUBLIC_BUILD_ID=
ANALYZE=false
PORT=3000
