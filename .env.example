# V1 Vendor Panel API
NEXT_PUBLIC_API_BASE_URL=

# Client-side auth config
NEXT_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh

# Cookie security: set to "true" only for HTTPS (including *.vercel.app).
# On plain HTTP localhost it MUST be absent/false or cookies are dropped silently.
COOKIE_SECURE=

# Supabase config for storage client and realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional build identifier surfaced by the /_health endpoint
NEXT_PUBLIC_BUILD_ID=

# Local dev
# COOKIE_SECURE=

# JWT verification strategy
# The gateway signs access tokens with Supabase HS256 by default and does not
# expose a JWKS endpoint. Set JWT_VERIFY_SIGNATURE=false to verify tokens by
# decoding only (expiry/issuer/audience are still checked), or provide the
# SUPABASE_JWT_SECRET to verify HS256 signatures locally.
JWT_VERIFY_SIGNATURE=false
SUPABASE_JWT_SECRET=
JWKS_URL=
JWT_ALGORITHMS=HS256
